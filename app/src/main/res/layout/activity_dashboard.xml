<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0B0E11">

    <!-- Заголовок -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#1E2329"
        android:padding="16dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tv_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Дашборд аналитики"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#F0B90B"
            android:gravity="center_vertical" />

        <Button
            android:id="@+id/btn_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:text="←"
            android:textSize="20sp"
            android:textColor="#EAECEF"
            android:background="@drawable/btn_circle_dark"
            android:stateListAnimator="@null" />
    </LinearLayout>

    <!-- Кнопки управления -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="16dp"
        android:gravity="center_vertical">

        <Button
            android:id="@+id/btn_refresh"
            android:layout_width="0dp"
            android:layout_height="46dp"
            android:layout_weight="1"
            android:text="Обновить"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#0B0E11"
            android:backgroundTint="#F0B90B"
            android:layout_marginEnd="8dp"
            android:stateListAnimator="@null"
            android:insetTop="0dp"
            android:insetBottom="0dp" />

        <Button
            android:id="@+id/btn_date_range"
            android:layout_width="0dp"
            android:layout_height="46dp"
            android:layout_weight="1"
            android:text="📅 Весь период"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#EAECEF"
            android:backgroundTint="#2B3139"
            android:layout_marginStart="8dp"
            android:stateListAnimator="@null"
            android:insetTop="0dp"
            android:insetBottom="0dp" />
    </LinearLayout>

    <!-- Информация о выбранном периоде -->
    <TextView
        android:id="@+id/tv_date_range_info"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Весь период"
        android:textSize="11sp"
        android:textColor="#848E9C"
        android:gravity="center"
        android:layout_marginTop="6dp"
        android:layout_marginBottom="8dp" />

    <!-- Навигация по неделям (скрыта) -->
    <LinearLayout
        android:id="@+id/layout_week_nav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="12dp"
        android:gravity="center_vertical"
        android:visibility="gone">

        <Button
            android:id="@+id/btn_prev_week"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:text="◀"
            android:textSize="14sp"
            android:textColor="#F0B90B"
            android:background="@drawable/btn_circle_dark"
            android:layout_marginEnd="10dp"
            android:stateListAnimator="@null"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tv_week_info"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text=""
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#EAECEF"
            android:gravity="center"
            android:background="#1E2329"
            android:padding="10dp"
            android:visibility="gone" />

        <Button
            android:id="@+id/btn_next_week"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:text="▶"
            android:textSize="14sp"
            android:textColor="#F0B90B"
            android:background="@drawable/btn_circle_dark"
            android:layout_marginStart="10dp"
            android:stateListAnimator="@null"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:visibility="gone" />
    </LinearLayout>

    <!-- Фильтр по лигам -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="16dp"
        android:gravity="center_vertical"
        android:background="#1E2329"
        android:padding="10dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Лига:"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#EAECEF"
            android:layout_marginEnd="10dp" />

        <Spinner
            android:id="@+id/spinner_league"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:background="@drawable/spinner_bg_dark"
            android:padding="8dp" />
    </LinearLayout>

    <!-- Основной контент -->
    <ScrollView
        android:id="@+id/scroll_view"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="8dp">

            <!-- Круговая диаграмма -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="4dp"
                android:layout_marginBottom="10dp"
                app:cardBackgroundColor="#1E2329"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Общая проходимость"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="#EAECEF"
                        android:gravity="center"
                        android:layout_marginBottom="12dp" />

                    <com.github.mikephil.charting.charts.PieChart
                        android:id="@+id/pie_chart"
                        android:layout_width="match_parent"
                        android:layout_height="280dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Гистограмма по дням -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="4dp"
                android:layout_marginBottom="10dp"
                app:cardBackgroundColor="#1E2329"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="По дням недели"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#848E9C"
                        android:gravity="center"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Нажмите на столбец для детализации"
                        android:textSize="10sp"
                        android:textColor="#5E6673"
                        android:gravity="center"
                        android:layout_marginBottom="8dp" />

                    <com.github.mikephil.charting.charts.BarChart
                        android:id="@+id/bar_chart_day"
                        android:layout_width="match_parent"
                        android:layout_height="220dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Гистограмма по часам -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="4dp"
                android:layout_marginBottom="10dp"
                app:cardBackgroundColor="#1E2329"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="По часам суток"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#848E9C"
                        android:gravity="center"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Нажмите на столбец для детализации"
                        android:textSize="10sp"
                        android:textColor="#5E6673"
                        android:gravity="center"
                        android:layout_marginBottom="8dp" />

                    <com.github.mikephil.charting.charts.BarChart
                        android:id="@+id/bar_chart_hour"
                        android:layout_width="match_parent"
                        android:layout_height="220dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- НОВАЯ ГИСТОГРАММА: Градация по startkf -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="4dp"
                android:layout_marginBottom="10dp"
                app:cardBackgroundColor="#1E2329"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Проходимость по градации startkf"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#848E9C"
                        android:gravity="center"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Шаг 0.05 | Нажмите на столбец для детализации"
                        android:textSize="10sp"
                        android:textColor="#5E6673"
                        android:gravity="center"
                        android:layout_marginBottom="8dp" />

                    <com.github.mikephil.charting.charts.BarChart
                        android:id="@+id/bar_chart_kf_range"
                        android:layout_width="match_parent"
                        android:layout_height="250dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Гистограмма по лигам -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="4dp"
                android:layout_marginBottom="10dp"
                app:cardBackgroundColor="#1E2329"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Топ-15 лиг по проходимости"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#848E9C"
                        android:gravity="center"
                        android:layout_marginBottom="8dp" />

                    <com.github.mikephil.charting.charts.HorizontalBarChart
                        android:id="@+id/bar_chart_league"
                        android:layout_width="match_parent"
                        android:layout_height="350dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Детальная таблица -->
            <androidx.cardview.widget.CardView
                android:id="@+id/layout_detail_table"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="4dp"
                android:layout_marginBottom="10dp"
                app:cardBackgroundColor="#1E2329"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                android:visibility="visible">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="8dp">

                    <TextView
                        android:id="@+id/tv_detail_title"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Экспрессы"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#F0B90B"
                        android:gravity="center"
                        android:layout_marginBottom="10dp" />

                    <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:scrollbars="horizontal"
                        android:fillViewport="true">

                        <LinearLayout
                            android:id="@+id/layout_detail_content"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:minWidth="700dp" />
                    </HorizontalScrollView>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Текстовая сводка (скрыта) -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="4dp"
                android:layout_marginBottom="24dp"
                app:cardBackgroundColor="#1E2329"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Сводка"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="#EAECEF"
                        android:gravity="center"
                        android:layout_marginBottom="10dp" />

                    <ScrollView
                        android:layout_width="match_parent"
                        android:layout_height="400dp"
                        android:background="#0B0E11"
                        android:padding="10dp">

                        <TextView
                            android:id="@+id/tv_stats"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text=""
                            android:textSize="11sp"
                            android:fontFamily="monospace"
                            android:textColor="#848E9C"
                            android:lineSpacingExtra="3dp" />
                    </ScrollView>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>
</LinearLayout>