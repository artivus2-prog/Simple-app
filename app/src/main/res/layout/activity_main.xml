<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0B0E11">

    <!-- Заголовок -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#1E2329"
        android:padding="16dp"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Fonbet Bot"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#F0B90B" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Экспрессы"
            android:textSize="13sp"
            android:textColor="#848E9C" />
    </LinearLayout>

    <!-- Таблица с собственной прокруткой -->
    <ScrollView
        android:id="@+id/scroll_view"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="3"
        android:fillViewport="false"
        android:scrollbars="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="8dp">

            <androidx.cardview.widget.CardView
                android:id="@+id/layout_detail_table"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="4dp"
                android:layout_marginBottom="8dp"
                app:cardBackgroundColor="#1E2329"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                android:visibility="visible">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="8dp">

                    <TextView
                        android:id="@+id/tv_detail_title"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Экспрессы"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#F0B90B"
                        android:gravity="center"
                        android:layout_marginBottom="6dp" />

                    <!-- Переключатель Все/Активные -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:id="@+id/tv_filter_label"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Все"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:textColor="#F0B90B"
                            android:layout_marginEnd="8dp" />

                        <Switch
                            android:id="@+id/switch_filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:thumbTint="#F0B90B"
                            android:trackTint="#2B3139" />
                    </LinearLayout>

                    <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:scrollbars="horizontal"
                        android:fillViewport="true">

                        <LinearLayout
                            android:id="@+id/layout_detail_content"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:minWidth="440dp" />
                    </HorizontalScrollView>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

    <!-- Окно логов -->
    <androidx.cardview.widget.CardView
        android:id="@+id/layout_logs"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="2"
        android:layout_margin="4dp"
        app:cardBackgroundColor="#1E2329"
        app:cardCornerRadius="12dp"
        app:cardElevation="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="4dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Логи системы"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="#F0B90B"
                    android:gravity="center" />

                <Button
                    android:id="@+id/btn_clear_logs"
                    android:layout_width="70dp"
                    android:layout_height="28dp"
                    android:text="Очистить"
                    android:textSize="9sp"
                    android:textColor="#EAECEF"
                    android:backgroundTint="#2B3139"
                    android:stateListAnimator="@null"
                    android:insetTop="0dp"
                    android:insetBottom="0dp" />
            </LinearLayout>

            <ScrollView
                android:id="@+id/scroll_logs"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:background="#0B0E11"
                android:padding="6dp"
                android:scrollbars="vertical"
                android:fillViewport="false">

                <TextView
                    android:id="@+id/tv_logs"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Логи системы..."
                    android:textSize="9sp"
                    android:fontFamily="monospace"
                    android:textColor="#848E9C"
                    android:lineSpacingExtra="1dp" />
            </ScrollView>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Кнопки внизу -->
<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center"
    android:padding="8dp"
    android:background="#0B0E11">

    <Button
        android:id="@+id/btn_analytics"
        android:layout_width="0dp"
        android:layout_height="44dp"
        android:layout_weight="2"
        android:text="АНАЛИТИКА"
        android:textSize="12sp"
        android:textStyle="bold"
        android:textColor="#0B0E11"
        android:backgroundTint="#F0B90B"
        android:layout_marginEnd="4dp"
        android:stateListAnimator="@null" />

    <Button
        android:id="@+id/btn_settings"
        android:layout_width="0dp"
        android:layout_height="44dp"
        android:layout_weight="1"
        android:text="⚙"
        android:textSize="18sp"
        android:textColor="#EAECEF"
        android:backgroundTint="#2B3139"
        android:layout_marginStart="4dp"
        android:stateListAnimator="@null" />
</LinearLayout>

</LinearLayout>