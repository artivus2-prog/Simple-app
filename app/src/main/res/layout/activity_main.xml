<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0B0E11">

    <!-- Заголовок -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#1E2329"
        android:padding="16dp"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Fonbet Bot"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#F0B90B" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Экспрессы"
            android:textSize="13sp"
            android:textColor="#848E9C" />
    </LinearLayout>

    <!-- Основной контент -->
    <ScrollView
        android:id="@+id/scroll_view"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="8dp">

            <!-- Таблица экспрессов -->
            <androidx.cardview.widget.CardView
                android:id="@+id/layout_detail_table"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="4dp"
                android:layout_marginBottom="10dp"
                app:cardBackgroundColor="#1E2329"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                android:visibility="visible">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="8dp">

                    <TextView
                        android:id="@+id/tv_detail_title"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Экспрессы"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#F0B90B"
                        android:gravity="center"
                        android:layout_marginBottom="10dp" />

                    <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:scrollbars="horizontal"
                        android:fillViewport="true">

                        <LinearLayout
                            android:id="@+id/layout_detail_content"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:minWidth="440dp" />
                    </HorizontalScrollView>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

    <!-- Кнопка внизу -->
    <Button
        android:id="@+id/btn_analytics"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="ПЕРЕЙТИ К АНАЛИТИКЕ"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="#0B0E11"
        android:backgroundTint="#F0B90B"
        android:layout_margin="12dp"
        android:stateListAnimator="@null" />

</LinearLayout>