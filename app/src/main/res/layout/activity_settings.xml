<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0B0E11"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Заголовок -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="20dp">

            <Button
                android:id="@+id/btn_back"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:text="←"
                android:textSize="20sp"
                android:textColor="#EAECEF"
                android:background="@drawable/btn_circle_dark"
                android:stateListAnimator="@null" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Настройки"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#F0B90B"
                android:gravity="center"
                android:layout_marginEnd="40dp" />
        </LinearLayout>

        <!-- Минимальный коэффициент экспресса -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Минимальный коэффициент экспресса"
            android:textSize="13sp"
            android:textColor="#EAECEF"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <EditText
                android:id="@+id/et_all_min_kef"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="1.67"
                android:textSize="14sp"
                android:textColor="#EAECEF"
                android:background="#1E2329"
                android:padding="12dp"
                android:inputType="numberDecimal"
                android:gravity="center" />
        </LinearLayout>

        <!-- Разделитель -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#2B3139"
            android:layout_marginBottom="16dp" />

        <!-- Заголовок секции коэффициентов -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Отбор по коэффициентам"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#F0B90B"
            android:layout_marginBottom="12dp" />

        <!-- Тип 924 - 1Х -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="1Х (футбол/хоккей)"
            android:textSize="12sp"
            android:textColor="#848E9C"
            android:layout_marginBottom="6dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Мин:"
                android:textSize="12sp"
                android:textColor="#848E9C"
                android:layout_marginEnd="8dp" />

            <EditText
                android:id="@+id/et_type_924_min"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="1.15"
                android:textSize="13sp"
                android:textColor="#EAECEF"
                android:background="#1E2329"
                android:padding="10dp"
                android:inputType="numberDecimal"
                android:gravity="center"
                android:layout_marginEnd="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Макс:"
                android:textSize="12sp"
                android:textColor="#848E9C"
                android:layout_marginEnd="8dp" />

            <EditText
                android:id="@+id/et_type_924_max"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="1.50"
                android:textSize="13sp"
                android:textColor="#EAECEF"
                android:background="#1E2329"
                android:padding="10dp"
                android:inputType="numberDecimal"
                android:gravity="center" />
        </LinearLayout>

        <!-- Тип 927 - Фора 1 (+1.5) -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Фора 1 (+1.5) (футбол/хоккей)"
            android:textSize="12sp"
            android:textColor="#848E9C"
            android:layout_marginBottom="6dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Мин:"
                android:textSize="12sp"
                android:textColor="#848E9C"
                android:layout_marginEnd="8dp" />

            <EditText
                android:id="@+id/et_type_927_min"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="1.15"
                android:textSize="13sp"
                android:textColor="#EAECEF"
                android:background="#1E2329"
                android:padding="10dp"
                android:inputType="numberDecimal"
                android:gravity="center"
                android:layout_marginEnd="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Макс:"
                android:textSize="12sp"
                android:textColor="#848E9C"
                android:layout_marginEnd="8dp" />

            <EditText
                android:id="@+id/et_type_927_max"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="1.50"
                android:textSize="13sp"
                android:textColor="#EAECEF"
                android:background="#1E2329"
                android:padding="10dp"
                android:inputType="numberDecimal"
                android:gravity="center" />
        </LinearLayout>

        <!-- Тип 928 - Фора 2 (+1.5) -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Фора 2 (+1.5) (футбол/хоккей)"
            android:textSize="12sp"
            android:textColor="#848E9C"
            android:layout_marginBottom="6dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Мин:"
                android:textSize="12sp"
                android:textColor="#848E9C"
                android:layout_marginEnd="8dp" />

            <EditText
                android:id="@+id/et_type_928_min"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="1.15"
                android:textSize="13sp"
                android:textColor="#EAECEF"
                android:background="#1E2329"
                android:padding="10dp"
                android:inputType="numberDecimal"
                android:gravity="center"
                android:layout_marginEnd="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Макс:"
                android:textSize="12sp"
                android:textColor="#848E9C"
                android:layout_marginEnd="8dp" />

            <EditText
                android:id="@+id/et_type_928_max"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="1.50"
                android:textSize="13sp"
                android:textColor="#EAECEF"
                android:background="#1E2329"
                android:padding="10dp"
                android:inputType="numberDecimal"
                android:gravity="center" />
        </LinearLayout>

        <!-- Разделитель -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#2B3139"
            android:layout_marginBottom="16dp" />

        <!-- Таймаут -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Таймаут обращения к сервису (сек)"
            android:textSize="13sp"
            android:textColor="#EAECEF"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/et_timeout"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="60"
            android:textSize="14sp"
            android:textColor="#EAECEF"
            android:background="#1E2329"
            android:padding="12dp"
            android:inputType="number"
            android:gravity="center"
            android:layout_marginBottom="16dp" />

        <!-- Максимальное количество одновременно активных экспрессов -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Максимум одновременно активных экспрессов"
            android:textSize="13sp"
            android:textColor="#EAECEF"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/et_max_active_exp"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="5"
            android:textSize="14sp"
            android:textColor="#EAECEF"
            android:background="#1E2329"
            android:padding="12dp"
            android:inputType="number"
            android:gravity="center"
            android:layout_marginBottom="16dp" />

        <!-- Максимальное количество матчей в экспрессе -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Максимум матчей в экспрессе"
            android:textSize="13sp"
            android:textColor="#EAECEF"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/et_max_matches"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="2"
            android:textSize="14sp"
            android:textColor="#EAECEF"
            android:background="#1E2329"
            android:padding="12dp"
            android:inputType="number"
            android:gravity="center"
            android:layout_marginBottom="24dp" />

        <!-- Кнопки -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <Button
                android:id="@+id/btn_reset"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="Сбросить"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#EAECEF"
                android:backgroundTint="#2B3139"
                android:layout_marginEnd="8dp"
                android:stateListAnimator="@null" />

            <Button
                android:id="@+id/btn_save"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="Сохранить"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#0B0E11"
                android:backgroundTint="#03A66D"
                android:layout_marginStart="8dp"
                android:stateListAnimator="@null" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>