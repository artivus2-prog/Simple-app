<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Основная тема Bybit -->
    <style name="Theme.FonbetBot" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Основной цвет (золотой/жёлтый Bybit) -->
        <item name="colorPrimary">#F7A600</item>
        <item name="colorPrimaryVariant">#E59400</item>
        <item name="colorOnPrimary">#000000</item>

        <!-- Вторичный цвет -->
        <item name="colorSecondary">#F7A600</item>
        <item name="colorSecondaryVariant">#E59400</item>
        <item name="colorOnSecondary">#000000</item>

        <!-- Акцентный цвет для ripple и других эффектов -->
        <item name="colorControlActivated">#F7A600</item>
        <item name="colorControlHighlight">#33F7A600</item>

        <!-- Цвет фона -->
        <item name="android:colorBackground">#0B0E11</item>
        <item name="colorSurface">#1E2329</item>
        <item name="colorOnSurface">#EAECEF</item>
        <item name="colorOnBackground">#EAECEF</item>

        <!-- Цвет ошибки -->
        <item name="colorError">#F6465D</item>
        <item name="colorOnError">#FFFFFF</item>

        <!-- Статус-бар -->
        <item name="android:statusBarColor">#0B0E11</item>
        <item name="android:navigationBarColor">#0B0E11</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>

        <!-- Карточки -->
        <item name="cardViewStyle">@style/CardView.Bybit</item>
    </style>

    <!-- Стиль карточек -->
    <style name="CardView.Bybit" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">#1E2329</item>
        <item name="cardCornerRadius">8dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">#2B3139</item>
        <item name="strokeWidth">1dp</item>
    </style>
</resources>